# ── AI Keys ────────────────────────────────────────────────────────────────────
# Gemini: builds knowledge-context docs for the Aether Agent Layer, and acts as
# the fallback AI when the agent layer is unavailable.
GEMINI_API_KEY=your_key_here

# ElevenLabs: text-to-speech / speech-to-text for voice features.
ELEVENLABS_API_KEY=your_key_here

# ── ZO Email Agent ─────────────────────────────────────────────────────────────
# Shared secret for the hosted ZO daily-digest endpoint (armaanking.zo.space).
EMAIL_SUMMARY_SHARED_SECRET=your_secret_here

# ── NTU Module Catalog (optional) ──────────────────────────────────────────────
# Optional JSON endpoint returning NTU modules (NTUMods-style export).
# If unset, the app serves a built-in mock NTU CS catalog. No scraping is done.
NTU_CATALOG_URL=

# ── Aether Agent Layer (internal LLM platform) ─────────────────────────────────
# These configure the underlying hosted agent platform the copilot talks to.
# Leave blank to run fully on the Gemini fallback (recommended for local demos).
# Display name of the agent we create/reuse.
TERPAI_AGENT_NAME=Aether Study Assistant

# Agent chat URL (copy from the agent platform UI).
TERPAI_AGENT_URL=

# Bearer JWT token for the agent platform API.
# Grab from the platform in Chrome → F12 → Network → send any message →
# copy the Authorization: Bearer ... value. Valid ~30 minutes.
TERPAI_TOKEN=
